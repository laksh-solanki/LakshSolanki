# Environment
NODE_ENV=development

# MongoDB Connection
MONGODB_DB_NAME=your-db-name
MONGODB_URI=mongodb://localhost:27017/your-db

# Server Settings
HOST=0.0.0.0
PORT=5001

# CORS Settings
CORS_ORIGINS=*

# Security Settings
ENABLE_SECURITY_HEADERS=true
ENABLE_COMPRESSION=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_ALLOW_LIST=

# Trust Proxy (set true if behind reverse proxy)
TRUST_PROXY=false

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.0-flash
GROQ_API_KEY=your-groq-api-key
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=your-nvidia-api-key
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_CHAT_MODEL=microsoft/phi-3.5-mini-instruct
AI_DEFAULT_PROVIDER=auto

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project

# Admin Key (for protected endpoints)
ADMIN_KEY=your-secure-admin-key
