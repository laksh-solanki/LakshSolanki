{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "./",
    "ignoreDeprecations": "6.0",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "scripthost"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "target": "esnext"
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "include": [
    "src/**/*",
    "vite.config.*"
  ]
}